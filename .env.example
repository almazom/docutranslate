DOCUTRANSLATE_DEFAULT_RETRY=2
DOCUTRANSLATE_DEFAULT_THINKING=disable
DOCUTRANSLATE_DEFAULT_SYSTEM_PROXY_ENABLE=false
DOCUTRANSLATE_DEFAULT_CONVERT_ENGINE=mineru
DOCUTRANSLATE_DEFAULT_MINERU_TOKEN=
